
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                            String              @id @default(cuid())
  email                         String?             @unique
  passwordHash                  String?
  name                          String
  role                          String              @default("USER")
  userType                      String              @default("real_user")
  status                        String              @default("active")
  birthYear                     Int?
  ageSnapshot                   Int?
  ageGroup                      String?
  gender                        String              @default("male")
  occupation                    String?
  occupationCategory            String?
  regionCode                    String              @default("VN-HCM")
  regionName                    String              @default("Ho Chi Minh City")
  country                       String              @default("Vietnam")
  goal                          String?
  theme                         String              @default("dark")
  currentRankCode               String              @default("E")
  currentOverallScore           Float               @default(0)
  currentJobCode                String              @default("general")
  currentPlanCode               String              @default("balanced")
  trainingIntensity             String              @default("balanced")
  hasCompletedInitialMeasurement Boolean            @default(false)
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
  lastActiveAt                  DateTime?

  sessions                      Session[]
  userMetrics                   UserMetric[]
  metricInputs                  MetricInput[]
  levelingResults               LevelingResult[]
  generatedTasks                GeneratedTask[]
  feedback                      Feedback[]
  activityLogs                  ActivityLog[]
  systemLogs                    SystemLog[]
  exportLogs                    ExportLog[]         @relation("AdminExports")
  virtualMetadata               VirtualUserMetadata?
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MetricDefinition {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  unitLabel         String
  displayOrder      Int
  aggregationMethod String
  isLoopActive      Boolean             @default(true)
  logicVersion      String              @default("schema_v0_3")
  measureConfigJson String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  userMetrics       UserMetric[]
  metricInputs      MetricInput[]
  levelingResults   LevelingResult[]
  taskTemplates     TaskTemplate[]
}

model UserMetric {
  id                 String            @id @default(cuid())
  userId             String
  metricDefinitionId String
  score              Float             @default(0)
  rankCode           String            @default("E")
  rawValueJson       String?
  confidenceStatus   String            @default("missing")
  lastMeasuredAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricDefinition   MetricDefinition  @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)

  @@unique([userId, metricDefinitionId])
}

model MetricInput {
  id                  String            @id @default(cuid())
  userId              String
  metricDefinitionId  String
  rawInputJson        String
  normalizedInputJson String
  source              String            @default("manual_input")
  createdAt           DateTime          @default(now())

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricDefinition    MetricDefinition  @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  levelingResults     LevelingResult[]
}

model LevelingResult {
  id                    String            @id @default(cuid())
  userId                String
  metricDefinitionId    String
  metricInputId         String?
  rawScore              Float
  finalScore            Float
  rankCode              String
  logicVersion          String
  profileSnapshotJson   String
  calculationDetailJson String
  createdAt             DateTime          @default(now())

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricDefinition      MetricDefinition  @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  metricInput           MetricInput?      @relation(fields: [metricInputId], references: [id], onDelete: SetNull)
}

model TaskTemplate {
  id               String           @id @default(cuid())
  taskCode         String           @unique
  metricDefinitionId String
  taskType         String
  title            String
  description      String
  cycleGroup       String?
  cycleOrder       Int?
  isLoop           Boolean          @default(true)
  isDaily          Boolean          @default(false)
  estimatedMinutes Int              @default(20)
  volumeType       String?
  configJson       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  metricDefinition MetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  generatedTasks   GeneratedTask[]
}

model GeneratedTask {
  id               String       @id @default(cuid())
  userId           String
  taskTemplateId   String
  metricCode       String
  taskType         String
  title            String
  description      String
  scheduledDate    String
  weekKey          String
  loopNumber       Int?
  isLoop           Boolean      @default(true)
  reasonJson       String
  volumeJson       String?
  logicVersion     String
  status           String       @default("new")
  rewardGranted    Float?
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTemplate     TaskTemplate @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduledDate, taskTemplateId, loopNumber])
}

model RateLimitWindow {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String?
  type            String
  relatedMetric   String?
  message         String
  status          String   @default("open")
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id               String   @id @default(cuid())
  userId           String?
  eventType        String
  eventDetailJson  String
  createdAt        DateTime @default(now())

  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SystemLog {
  id               String   @id @default(cuid())
  userId           String?
  logType          String
  message          String
  stackJson        String?
  createdAt        DateTime @default(now())

  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ExportLog {
  id               String   @id @default(cuid())
  adminId          String
  exportType       String
  filtersJson      String
  createdAt        DateTime @default(now())

  admin            User     @relation("AdminExports", fields: [adminId], references: [id], onDelete: Cascade)
}

model VirtualUserMetadata {
  id                   String   @id @default(cuid())
  userId               String   @unique
  scenarioType         String
  scenarioName         String
  batchId              String?
  createdBy            String?
  simulationConfigJson String?
  notes                String?

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
